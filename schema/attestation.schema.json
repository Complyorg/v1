{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comply.org/schema/attestation.schema.json",
  "title": "Comply.org Vendor Attestation",
  "description": "A public compliance attestation for a vendor or data processor, following the Comply.org standard.",
  "type": "object",
  "required": ["$complyVersion", "slug", "name", "category", "certifications", "frameworks", "dataLocations", "aiCapabilities", "aiTechniques", "transparencyScore", "expertReviews"],
  "properties": {
    "$complyVersion": {
      "type": "string",
      "enum": ["1.0", "1.1"],
      "description": "Version of the Comply.org Attestation Standard."
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "URL-safe unique identifier for the vendor."
    },
    "name": {
      "type": "string",
      "description": "Legal or trading name of the vendor."
    },
    "category": {
      "type": "string",
      "description": "Primary vendor category (e.g., 'Analytics & BI', 'Cloud Infrastructure')."
    },
    "subcategory": {
      "type": ["string", "null"],
      "description": "Optional subcategory within the primary category."
    },
    "description": {
      "type": ["string", "null"],
      "description": "Brief description of the vendor's services."
    },
    "website": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "privacyPolicyUrl": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "URL of the vendor's public privacy notice."
    },
    "trustCenterUrl": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "dpaUrl": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "URL of the vendor's Data Processing Agreement."
    },
    "securityPageUrl": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "certifications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Security and privacy certifications held (e.g., 'ISO 27001', 'SOC 2 Type II')."
    },
    "frameworks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Regulatory frameworks the vendor claims compliance with (e.g., 'GDPR', 'CCPA')."
    },
    "gdprCompliant": { "type": ["boolean", "null"] },
    "ccpaCompliant": { "type": ["boolean", "null"] },
    "hipaaCompliant": { "type": ["boolean", "null"] },
    "dataLocations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Countries or regions where data is processed or stored."
    },
    "hasEuDataCenter": { "type": ["boolean", "null"] },
    "subprocessors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "purpose"],
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "location": { "type": ["string", "null"] }
        }
      },
      "description": "List of sub-processors used by the vendor."
    },
    "transferSafeguards": {
      "type": ["string", "null"],
      "description": "International data transfer mechanism (e.g., 'SCCs', 'Adequacy Decision', 'BCRs')."
    },
    "supportsDsars": {
      "type": ["boolean", "null"],
      "description": "Whether the vendor supports Data Subject Access Requests."
    },
    "hasDesignatedDpo": {
      "type": ["boolean", "null"],
      "description": "Whether the vendor has a designated Data Protection Officer."
    },
    "hasRecentBreach": {
      "type": ["boolean", "null"],
      "description": "Whether the vendor has disclosed a recent data breach."
    },
    "encryptionAtRest": { "type": ["boolean", "null"] },
    "encryptionInTransit": { "type": ["boolean", "null"] },
    "penTestFrequency": {
      "type": ["string", "null"],
      "description": "How often penetration testing is performed (e.g., 'Annually', 'Quarterly')."
    },
    "breachNotificationDays": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Maximum days to notify affected parties after a breach."
    },
    "dataRetentionPolicy": {
      "type": ["string", "null"],
      "description": "Data retention period or policy summary."
    },
    "privacyTechnologies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Privacy Enhancing Technologies implemented (e.g., 'Tokenization', 'Differential Privacy')."
    },
    "euAiActCompliant": { "type": ["boolean", "null"] },
    "aiCapabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "aiTechniques": {
      "type": "array",
      "items": { "type": "string" }
    },
    "euAiActRole": {
      "type": ["string", "null"],
      "description": "Role under the EU AI Act (e.g., 'Provider', 'Deployer')."
    },
    "iso42001Certified": { "type": ["boolean", "null"] },
    "aiDisclosure": {
      "type": ["object", "null"],
      "description": "Structured AI model disclosure. Null when AI usage has not been assessed.",
      "required": ["status", "transparencyLevel", "models"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["none", "disclosed", "undisclosed"],
          "description": "'none' = no AI used, 'disclosed' = AI models provided, 'undisclosed' = AI used but models not provided."
        },
        "transparencyLevel": {
          "type": "string",
          "enum": ["transparent", "partial", "opaque", "n/a"],
          "description": "AI transparency classification."
        },
        "models": {
          "type": "array",
          "items": { "$ref": "#/$defs/aiModel" },
          "description": "AI models used. Empty when status is 'none' or 'undisclosed'."
        }
      }
    },
    "transparencyScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Percentage score reflecting how much compliance information the vendor has disclosed."
    },
    "dpaAnalysis": {
      "type": ["object", "null"],
      "description": "Automated analysis of the vendor's Data Processing Agreement.",
      "properties": {
        "overallScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "gdpr": { "$ref": "#/$defs/lawAnalysis" },
        "ccpa": { "$ref": "#/$defs/lawAnalysis" },
        "usState": { "$ref": "#/$defs/lawAnalysis" }
      }
    },
    "expertReviews": {
      "type": "array",
      "items": { "$ref": "expert-review.schema.json" },
      "description": "Expert assessments of the vendor's compliance posture. May be empty for self-reported attestations."
    },
    "generated": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date when this attestation was generated."
    }
  },
  "$defs": {
    "aiModel": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "description": "Model name (e.g., 'GPT-4o', 'Claude Sonnet 4')." },
        "type": { "type": "string", "description": "Model type (e.g., 'LLM', 'Image Generation', 'Classification')." },
        "provider": { "type": ["string", "null"], "description": "Organization providing the model (e.g., 'OpenAI', 'Anthropic')." },
        "euAiActRiskTier": { "type": ["string", "null"], "description": "EU AI Act risk classification." },
        "isOpenSource": { "type": ["boolean", "null"], "description": "Whether model weights are openly available." }
      }
    },
    "lawAnalysis": {
      "type": "object",
      "required": ["score", "total", "clauses"],
      "properties": {
        "score": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "clauses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "label", "found"],
            "properties": {
              "key": { "type": "string" },
              "label": { "type": "string" },
              "found": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
